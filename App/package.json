{
  "name": "techstock",
  "version": "2.0.0",
  "description": "Controle de estoque TechStock — AWS Learner Lab",
  "main": "server.js",
  "scripts": {
    "start":          "node server.js",
    "dev":            "node --watch server.js",
    "test":           "jest --forceExit --detectOpenHandles",
    "test:watch":     "jest --watch",
    "test:coverage":  "jest --coverage --forceExit --detectOpenHandles",
    "test:ci":        "jest --ci --coverage --forceExit --reporters=default --reporters=jest-junit"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch":       ["**/__tests__/**/*.test.js"],
    "testTimeout":     30000,
    "coverageDirectory": "coverage",
    "collectCoverageFrom": ["*.js", "!node_modules/**", "!coverage/**"],
    "coverageThresholds": {
      "global": { "lines": 60, "functions": 60 }
    },
    "verbose": true
  },
  "devDependencies": {
    "jest":       "^29.7.0",
    "jest-junit": "^16.0.0",
    "supertest":  "^6.3.4"
  },
  "dependencies": {
    "cors":                 "^2.8.5",
    "dotenv":               "^16.4.5",
    "express":              "^4.19.2",
    "express-async-errors": "^3.1.1",
    "helmet":               "^7.1.0",
    "pg":                   "^8.11.5",
    "prom-client":          "^15.1.2"
  }
}
