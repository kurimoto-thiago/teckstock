        }
      },
      {
        "id": 9,
        "type": "timeseries",
        "title": "Lat\u00eancia por Rota (se configurado)",
        "description": "Distribui\u00e7\u00e3o de tr\u00e1fego por endpoint",
        "gridPos": {
          "x": 12,
