    "panels": [
      {
        "id": 1,
        "type": "text",
        "title": "",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 24,
          "h": 2
        },
        "options": {
          "mode": "markdown",
          "content": "## \ud83d\udda5\ufe0f Infraestrutura EC2 \u2014 Backend e Monitoring\nM\u00e9tricas do sistema operacional coletadas via **node_exporter** (porta 9100)."
        }
      },
      {
        "id": 2,
        "type": "gauge",
        "title": "CPU Backend (%)",
        "description": "",
        "gridPos": {
          "x": 0,
          "y": 2,
          "w": 6,
          "h": 5
        },
        "datasource": {
          "type": "prometheus",
          "uid": "PBFA97CFB590B2093"
        },
        "targets": [
          {
            "expr": "round(100 - (avg(rate(node_cpu_seconds_total{job=\"node-exporter-backend\",mode=\"idle\"}[1m])) * 100), 0.1)",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "PBFA97CFB590B2093"
            },
            "legendFormat": ""
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 70
                },
                {
                  "color": "red",
                  "value": 90
                }
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          },
          "orientation": "auto",
          "showThresholdLabels": false,
          "showThresholdMarkers": true
        }
      },
